<div class="page">
  <h1 class="page-title">Our Dishes</h1>
  <div class="dish-grid">
    <% @dishes.each do |dish| %>
      <div class="dish-card">
        <div class="dish-image">
          <%= image_tag(dish.image_names, alt: dish.name) %>
        </div>
        <div class="dish-body">
          <p class="dish-badge <%= 'hidden' unless dish.bestseller %>">
            Bestseller
          </p>
          <h2 class="dish-name"><%= dish.name %></h2>
          <p class="dish-price">₱<%= number_with_precision(dish.price, precision: 2) %></p>
          <%# Quantity and Add to cart %>
          <div class="add-to-cart">
            <div class="quantity-control">
              <button class="qty-btn">−</button>
              <span class="qty-value">1</span>
              <button class="qty-btn">+</button>
            </div>
            <button class="add-btn">Add to Cart</button>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>